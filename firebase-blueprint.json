{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "JPY", "INR"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Task": {
      "title": "Task",
      "description": "A task or reminder created by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "completed": { "type": "boolean" },
        "dueDate": { "type": "string", "format": "date-time" },
        "reminderAt": { "type": "string", "format": "date-time" },
        "category": { "type": "string" },
        "priority": { "type": "string", "enum": ["High", "Medium", "Low"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "completed"]
    },
    "Expense": {
      "title": "Expense",
      "description": "An expense record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "category", "date"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the AI assistant chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "User tasks."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "User expenses."
    },
    "/chats/{userId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat history for each user."
    }
  }
}
